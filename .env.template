# Fleet Service - Variables de Entorno
# Copiar este archivo como .env y ajustar los valores según el entorno.
# cp .env.template .env

# Nombre del servicio (usado en logs y tracing)
SERVICE_NAME=fleet

# Puerto del servidor HTTP (Para Healthchecks y Métricas, si aplica)
HTTP_PORT=8081

# Puerto del servidor gRPC Principal
GRPC_PORT=9090

# URL de conexión a PostgreSQL
# Formato: postgres://<user>:<password>@<host>:<port>/<database>?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/school_tracking?sslmode=disable

# Entorno de ejecución (development | production)
ENVIRONMENT=development

# Nivel de log (debug | info | warn | error)
LOG_LEVEL=debug
